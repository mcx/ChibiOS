<clocktree>
  <settings>
    <prefixes clock_points="TCLK_" macros="TST_" cfgs="TST_CFG_" />
    <suffixes frequency="_FREQ" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
    </configs>
  </settings>
  <sources>
    <source point="BAD_SOURCE" enable="always" dynamic="no"
            input="OTHER" frequency="%I%">
      <description>source elements cannot depend on an upstream clock</description>
    </source>
  </sources>
  <clocks>
    <clock point="OTHER" enable="always" dynamic="no">
      <description>ordinary fixed clock</description>
      <derived frequency="16000000U" />
    </clock>
  </clocks>
</clocktree>
