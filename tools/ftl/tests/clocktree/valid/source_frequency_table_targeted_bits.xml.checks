# Targeted bits macros are emitted separately.
#define TST_CR_TABLEOSC_BITS
#define TST_CFGR_TABLEOSC_BITS
OSC_ON | OSC_FAST_CR_BITS
#define TST_CR_TABLEOSC_BITS                0U
OSC_FINE_BITS
OSC_FAST_BITS
OSC_SLOW_BITS

# Conditional frequency table values are emitted.
# The nominal source frequency is the default/post-reset table value.
#define TST_TABLEOSC_SOURCE_FREQ            12000000U
#define TST_TABLEOSC_FREQ
#if ((TST_CFG_OSC_MODE == OSC_FAST) && \
     (TST_CFG_OSC_FINE == TRUE)) || \
50000000U
48000000U
12000000U
