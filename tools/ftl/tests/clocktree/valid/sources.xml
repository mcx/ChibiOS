<clocktree>
  <settings>
    <prefixes clock_points="TCLK_" macros="TST_" cfgs="TST_CFG_" />
    <suffixes frequency="_FREQ" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
    </configs>
  </settings>
  <sources>
    <source point="NONE" enable="never" dynamic="no" frequency="0U">
      <description>pseudo-clock for disabled sources</description>
    </source>
    <source point="OSC" enable="manual" dynamic="yes" frequency="16000000U">
      <description>root oscillator</description>
      <bits enabled="RCC_OSC_ON" disabled="0U" />
    </source>
  </sources>
  <clocks>
    <clock point="SYSCLK" enable="always" dynamic="yes">
      <description>system clock mux</description>
      <mux name="SYSSEL">
        <input point="NONE">
          <bits value="SYSSEL_NONE" />
        </input>
        <input point="OSC" default="yes">
          <bits value="SYSSEL_OSC" />
        </input>
      </mux>
    </clock>
  </clocks>
</clocktree>
